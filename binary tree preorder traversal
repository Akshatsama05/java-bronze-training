class Solution {
    public List<Integer> preorderTraversal(TreeNode root) {
        List<Integer> res = new ArrayList<>();
        pre(root, res);
        return res;
    }

    void pre(TreeNode root, List<Integer> res) {
        if (root == null) return;
        
        res.add(root.val);        // Visit root
        pre(root.left, res);      // Traverse left
        pre(root.right, res);     // Traverse right
    }
}

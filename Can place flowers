class Solution {
    public boolean canPlaceFlowers(int[] flowerbed, int n) {
        int count = 0, zeros = 1;

        for (int f : flowerbed) {
            if (f == 0) {
                zeros++;
            } else {
                count += (zeros - 1) / 2;
                zeros = 0;
            }
        }

        zeros++;
        count += (zeros - 1) / 2;

        return count >= n;
    }
}

class Solution {

    public static void main(String[] args) {
        int[] nums = {1, 2, 3};
        int[] subset = new int[nums.length];
        generateSubsets(nums, 0, subset, 0);
    }

    static void generateSubsets(int[] nums, int index, int[] subset, int size) {

        if (index == nums.length) {
            printSubset(subset, size);
            return;
        }

        subset[size] = nums[index];
        generateSubsets(nums, index + 1, subset, size + 1);

   
        generateSubsets(nums, index + 1, subset, size);
    }

    static void printSubset(int[] subset, int size) {
        System.out.print("[");
        for (int i = 0; i < size; i++) {
            System.out.print(subset[i]);
            if (i < size - 1) System.out.print(", ");
        }
        System.out.println("]");
    }
}
